# --- Local dev environment template ----------------------------------------
# Copy to .env.local (npm run setup does this for you) and fill in the blanks.
# .env.local is gitignored; never commit secrets.

# Database --------------------------------------------------------------------
# Default points at the Postgres container started by docker compose
# (see docker-compose.yml). Change only if you want to point at Neon or another
# Postgres. Switch the adapter to SQLite by also setting DATABASE_TYPE=sqlite
# and DATABASE_URL=file:./database.sqlite.
DATABASE_URL="postgresql://clinic:clinic@localhost:5432/clinic"
# DATABASE_TYPE=sqlite

# Canonical site origin -------------------------------------------------------
# Drives canonical URLs, hreflang, JSON-LD, robots.txt and the sitemap.
# Leave unset to use the production default (https://www.khozrevanidze.ge).
# Set it on Vercel preview / staging / cPanel so those builds emit their own
# origin instead of the prod domain. No trailing slash needed (it's stripped).
# NEXT_PUBLIC_SITE_URL="https://staging.khozrevanidze.ge"

# Payload CMS -----------------------------------------------------------------
# Any non-empty value works locally. Generate a real one for staging/prod:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET="change-me-locally"

# Set to "true" to bypass TOTP 2FA on admin login during local testing.
# Leave unset/false to exercise the real 2FA flow.
TOTP_DISABLED=true

# Doctra (booking backend) ----------------------------------------------------
# The Doctra REST API powers /api/booking/*. Without these, the booking
# wizard returns empty service/timeslot lists but the rest of the site works.
# Ask the team for the actual credentials.
DOCTRA_API_URL="http://31.146.167.162:9090/doctra/hs/portal_exchange/v1"
DOCTRA_USER=""
DOCTRA_PASSWORD=""

# Vercel Blob (media uploads) -------------------------------------------------
# Optional locally — when empty, Payload falls back to disk uploads under
# /media. Required on Vercel deployments.
BLOB_READ_WRITE_TOKEN=""

# Google Cloud TTS (Georgian voice on /api/tts) -------------------------------
# Optional. Without it, /api/tts proxies to free Google Translate TTS only.
GOOGLE_TTS_API_KEY=""

# Google Reviews sync (admin Dashboard → "Google შეფასებების სინქი") ----------
# Setup: docs/HANDOVER.md → "Google Reviews setup". Without these, the sync
# button on the admin Dashboard returns an error; the site still works.
GOOGLE_PLACES_API_KEY=""
GOOGLE_PLACE_ID=""

# AI chat assistant (Gemini) --------------------------------------------------
# Powers the floating chat widget on every public page (ChatAssistant.tsx →
# /api/chat). Get a free key (1,500 reqs/day on Gemini 2.5 Flash) from
# https://aistudio.google.com/apikey — "Create API key" → copy → paste below.
# Without this key the chat button is still rendered but every send returns
# a 500 with a clear error pointing back here.
GEMINI_API_KEY=""

# Demo content seeder (POST /api/seed-demo) ----------------------------------
# Guards the seed route when it runs in production (NODE_ENV=production): the
# request must send a matching token via the `x-seed-token` header or `?token=`.
# Local dev (next dev) is open without it. Seeding is normally run from a local
# dev server pointed at the target DB — see docs/DEMO_SEED.md.
SEED_TOKEN=""
